<odoo>
    <record id="view_rental_training_lesson_form" model="ir.ui.view">
        <field name="name">rental_vehicles.training.lesson.form</field>
        <field name="model">rental_vehicles.training.lesson</field>
        <field name="arch" type="xml">
            <form string="Training Lesson">
                <header>
                    <button
                        name="action_plan"
                        type="object"
                        string="Plan"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />

                    <button
                        name="action_done"
                        type="object"
                        string="Done"
                        class="btn-success"
                        invisible="state != 'planned'"
                    />

                    <button
                        name="action_cancel"
                        type="object"
                        string="Cancel"
                        invisible="state in ['done', 'cancelled']"
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,planned,done"
                    />
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="instructor_id"/>
                    </group>

                    <group>
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                        <field name="duration_hours" widget="float_time"/>
                    </group>

                    <group>
                        <field name="price_per_hour"/>
                        <field name="amount_total"/>
                        <field name="currency_id" invisible="1"/>
                    </group>

                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="rental_vehicles.training_lesson_calendar" model="ir.ui.view">
        <field name="name">rental_vehicles.training.lesson.calendar</field>
        <field name="model">rental_vehicles.training.lesson</field>
        <field name="arch" type="xml">
            <calendar
                string="Training Schedule"
                date_start="start_datetime"
                date_stop="end_datetime"
                date_delay="duration_hours"
                color="state"
                mode="week"
                >
                <!-- quick_create="0" -->
                <field name="name"/>
                <field name="instructor_id"/>
                <field name="amount_total"/>
                <field name="notes"/>
            </calendar>
        </field>
    </record>

    <record id="rental_vehicles.training_lesson_action" model="ir.actions.act_window">
        <field name="name">Lessons</field>
        <field name="res_model">rental_vehicles.training.lesson</field>
        <field name="view_mode">calendar,list,form</field>
    </record>

</odoo>